# --- OpsAI CORE CONFIG ---
# See docs/CONFIGURATION.md for a full list of environment variables and documentation.
OPENAI_API_KEY=your_openai_api_key_here
DATABASE_URL=sqlite:///opsai.db

# --- PHASE 3: INTEGRATION DRIVERS ---

# GMAIL (Email Driver)
# How to get: https://myaccount.google.com/apppasswords
OPSAI_DRIVER_COMMUNICATION_ENABLED=false
OPSAI_DRIVER_GMAIL_USER=your_email@gmail.com
OPSAI_DRIVER_GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# LINEAR (Task Driver)
# How to get: https://linear.app/settings/api (Personal Access Tokens)
OPSAI_DRIVER_TASK_CREATION_ENABLED=false
OPSAI_DRIVER_LINEAR_KEY=lin_api_your_key_here
# Get Team ID from Linear Team Settings (URL usually contains it)
OPSAI_DRIVER_LINEAR_TEAM_ID=your_team_id_here
